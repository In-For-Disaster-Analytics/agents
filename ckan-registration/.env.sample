# OpenAI-compatible LLM endpoint used by semantic_bridge
OPENAI_BASE_URL=https://ai.tejas.tacc.utexas.edu
OPENAI_API_KEY=
CKAN_LLM_MODEL=Meta-Llama-3.3-70B-Instruct

# CKAN connection
CKAN_URL=https://ckan.tacc.utexas.edu
CKAN_AUTH_MODE=tapis_password
CKAN_API_TOKEN=
CKAN_USERNAME=
CKAN_PASSWORD=
CKAN_TAPIS_URL=https://portals.tapis.io/v3/oauth2/tokens
CKAN_OWNER_ORG=DSO-Institute
CKAN_DATASET_AUTHOR=William Mobley
CKAN_DATASET_AUTHOR_EMAIL=wmobley@tacc.utexas.edu
CKAN_DATASET_MAINTAINER=William Mobley
CKAN_DATASET_MAINTAINER_EMAIL=wmobley@tacc.utexas.edu
CKAN_DATASET_LICENSE_ID=cc-by
CKAN_DATASET_TYPE=dataset
CKAN_DATASET_ISOPEN=true
CKAN_DATASET_VERSION=
CKAN_DATASET_SPATIAL=
CKAN_TEMPORAL_COVERAGE_START=
CKAN_TEMPORAL_COVERAGE_END=

# Registration targets
CKAN_DATASET_NAME=yegua-jackson-aquifer-groundwater-availability-model-files
CKAN_DATASET_TITLE=
SOURCE_METADATA_URL=https://www.twdb.texas.gov/groundwater/models/gam/ygjk/ygjk.asp
GAM_RESOURCE_DIR=/corral-repl/tacc/aci/PT2050/projects/PTDATAX-286/twdb_gam_collection/Yegua-Jackson_Aquifer_GAM/Model_File/Yegua_Jackson_Model_Only/CD-2_ygjk_model/Modflow_2000

# Notebook-derived metadata registration
NOTEBOOK_PATH=../DSO-Institute-2026/Day-3/Morning/3_folium_mapping.ipynb
# Optional: override the inferred GitHub URL for the source notebook.
NOTEBOOK_SOURCE_URL=
NOTEBOOK_CKAN_DATASET_NAME=
NOTEBOOK_CKAN_DATASET_TITLE=
# Optional: dataset name, dataset UUID, or full CKAN dataset URL to update.
EXISTING_CKAN_ENTRY=

# Optional behavior
MAX_FILES=5000
CKAN_AGENT_STATE_DIR=/tmp/ckan-registration-agent

# --- Capability A: GAM discovery (Lonestar6 / Corral filesystem) ---
# Root directory containing all GAM model subdirectories.
# Example: /corral-repl/tacc/aci/PT2050/projects/PTDATAX-286/twdb_gam_collection
GAM_ROOT_DIR=

# Optional EPSG code assumed when no CRS is present in the MODFLOW DIS file.
# Applied only to Step 1 (DIS-based bbox) before the Texas-bounds sanity check.
MODFLOW_DEFAULT_EPSG=

# --- Capability B/D: LLM throttling ---
# Seconds to sleep between successive LLM/API calls.  Default: 4.0
# Applies to: persona-loop calls (author + evaluators, between rounds) and
# report PDF map-reduce per-chunk calls.
LLM_CALL_DELAY_SECONDS=4

# --- LLM retry / back-off (429 and transient 5xx) ---
# Maximum number of *retries* after the initial attempt.  Total attempts =
# LLM_MAX_RETRIES + 1.  Default: 5.
LLM_MAX_RETRIES=5
# Base delay (seconds) for exponential back-off: delay = base * 2^attempt.
# Default: 2.0
LLM_BACKOFF_BASE_SECONDS=2.0
# Maximum back-off cap in seconds.  Default: 60.0
LLM_BACKOFF_MAX_SECONDS=60.0

# --- CKAN throttling + retry ---
# Seconds to sleep before each CKAN API action (package_show/create/patch and
# every per-file resource_create/update/delete).  Default: 0.5.  Set to 0 to
# disable.  Prevents bulk per-file resource uploads from hammering CKAN.
CKAN_CALL_DELAY_SECONDS=0.5
# Retries for transient CKAN gateway errors (429/500/502/503/504) with
# exponential back-off.  Each resource upload is sequential and retried in
# place (file handle re-sought) so a 502 mid-upload doesn't break the run.
# Default: 5.
CKAN_MAX_RETRIES=5

# --- Register-by-reference (Tapis postit mode) ---
# When REGISTER_BY_REFERENCE=true, files stay on Corral/Tapis storage and a
# Tapis postit (redeemable HTTP URL) is minted per file and registered as a
# CKAN url-type resource instead of uploading file bytes.  Eliminates 502s
# from large bulk uploads.  Requires CKAN_AUTH_MODE=tapis_password (so the
# auth_header is a Bearer JWT that also works against Tapis Files).
#
# REGISTER_BY_REFERENCE=false

# Tapis storage system ID registered in your tenant (e.g. "corral-gam").
# Required when REGISTER_BY_REFERENCE=true.
# TAPIS_SYSTEM_ID=

# Absolute local path that maps to the Tapis system rootDir on the host where
# files are stored (used to compute the Tapis-relative path for each file).
# Required when REGISTER_BY_REFERENCE=true.
# TAPIS_SYSTEM_ROOTDIR=

# Tapis tenant base URL for the Files/postits API.
# Defaults to the tenant base inferred from CKAN_TAPIS_URL
# (i.e. "https://portals.tapis.io").
# TAPIS_FILES_BASE_URL=https://portals.tapis.io

# Postit lifetime in seconds.  Default 3153600000 (~100 years).
# Tapis tenants may cap this; if the tenant cap is lower, postits will expire
# and must be refreshed via tapis_links.refresh_postit_urls().
# POSTIT_VALID_SECONDS=3153600000

# Number of times a postit URL may be redeemed.  Default -1 (unlimited).
# POSTIT_ALLOWED_USES=-1
