# Service
CKAN_AGENT_API_HOST=0.0.0.0
CKAN_AGENT_API_PORT=8787
CKAN_AGENT_PUBLIC_BASE_URL=
CKAN_AGENT_STATE_DIR=/tmp/ckan-agent-api/ckan-registration
CKAN_AGENT_CHECKPOINT_DB=/tmp/ckan-agent-api/checkpoints.sqlite
CKAN_AGENT_UPLOAD_ROOT=/tmp/ckan-upload
CKAN_AGENT_LEGACY_DIR=../ckan-registration

# OpenAI-compatible LLM endpoint
OPENAI_BASE_URL=https://ai.tejas.tacc.utexas.edu
OPENAI_API_KEY=
CKAN_LLM_MODEL=Meta-Llama-3.3-70B-Instruct

# CKAN connection
CKAN_URL=https://ckan.tacc.utexas.edu
CKAN_AUTH_MODE=tapis_password
CKAN_API_TOKEN=
CKAN_USERNAME=
CKAN_PASSWORD=
CKAN_TAPIS_URL=https://portals.tapis.io/v3/oauth2/tokens
CKAN_OWNER_ORG=DSO-Institute
CKAN_DATASET_AUTHOR=William Mobley
CKAN_DATASET_AUTHOR_EMAIL=wmobley@tacc.utexas.edu
CKAN_DATASET_MAINTAINER=William Mobley
CKAN_DATASET_MAINTAINER_EMAIL=wmobley@tacc.utexas.edu
CKAN_DATASET_LICENSE_ID=cc-by
CKAN_DATASET_TYPE=dataset
CKAN_DATASET_ISOPEN=true
CKAN_DATASET_VERSION=
CKAN_DATASET_SPATIAL=
CKAN_TEMPORAL_COVERAGE_START=
CKAN_TEMPORAL_COVERAGE_END=

# MCP integration (dso_ckan_mcp). When enabled, CKAN tools are served by the
# running MCP server over HTTP; file tools stay in-process. Disabled => in-repo
# CKAN read tools are the fallback. The Tapis token is sent as an HTTP header.
CKAN_MCP_ENABLED=false
CKAN_MCP_URL=http://localhost:8100/mcp
CKAN_MCP_TIMEOUT=30
CKAN_MCP_SHARED_SECRET=
CKAN_MCP_TAPIS_TOKEN=

# Geo MCP server (dso-geo) as a second tool source. Personas get gdalinfo_extract
# only; transforms are gated. The Tapis token is injected server-side (never a
# model-visible arg). GEO_MCP_SHARED_SECRET must match the geo server's secret.
GEO_MCP_ENABLED=false
GEO_MCP_URL=http://localhost:8200/mcp
GEO_MCP_SHARED_SECRET=
GEO_MCP_TAPIS_TOKEN=
GEO_POLL_TIMEOUT=90
GEO_MAX_TRANSFORMS_PER_SESSION=5

# LangSmith tracing (optional — set key to enable).
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ckan-agent-api
LANGGRAPH_STRICT_MSGPACK=true
