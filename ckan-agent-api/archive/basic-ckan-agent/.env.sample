OPENAI_API_KEY=
OPENAI_BASE_URL=
CKAN_LLM_MODEL=Meta-Llama-3.3-70B-Instruct

# LLM request throttling (avoids 429 Too Many Requests). Lower the rate if you still see 429s.
CKAN_LLM_REQUESTS_PER_SECOND=1.0
CKAN_LLM_MAX_BURST=1.0
CKAN_LLM_RATE_CHECK_SECONDS=0.1
CKAN_LLM_MAX_RETRIES=6
CKAN_LLM_TIMEOUT_SECONDS=60

CKAN_BASE_URL=https://ckan.tacc.utexas.edu
CKAN_OPENAPI_URL=https://ckan.tacc.utexas.edu/api-specs/ckan-openapi.json
CKAN_API_TOKEN=
CKAN_AGENT_LOG_DIR=logs

